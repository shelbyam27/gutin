# WAJIB di production. Generate di PowerShell:
#   -join ((1..48) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
# Atau di bash: openssl rand -hex 32
# Minimal 32 karakter. Dipakai untuk sign session cookie admin.
SESSION_SECRET=ganti-dengan-string-acak-minimal-32-karakter-yang-panjang-dan-random

# URL publik (untuk URL email + URL webhook di settings).
# Saat dev biarkan kosong atau http://localhost:3000.
# Saat production isi dengan domain final, mis. https://toko.example.com
PUBLIC_BASE_URL=

# Lokasi database SQLite (opsional; default: ./data/store.db)
# DB_PATH=./data/store.db
